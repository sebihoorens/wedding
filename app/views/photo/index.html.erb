<section id="photo-index-leader" class="jumbotron text-center">
  <div class="container">
    <h1><%= t 'photo.civil_title' %></h1>
  </div>
</section>

<div class="gallery-row" id="gallery-row-civil">
  <% media_items.each do |item| %>
    <div class="gallery-item">
      <% case item[:type] %>
      <% when :image %>
        <a href="<%= cloudinary_image_url(item[:url]) %>" class="glightbox glightbox-civil" data-gallery="civil">
          <%= image_tag(cloudinary_image_url(item[:url]), width: '100%', loading: 'lazy', onload: "this.classList.add('loaded')") %>
        </a>
      <% when :video %>
        <a href="<%= item[:url] %>" class="glightbox glightbox-civil" data-gallery="civil" data-type="video" data-mute="true">
          <video width="100%" autoplay loop muted playsinline oncontextmenu="return false;">
            <source src="<%= item[:url] %>" type="video/mp4">
          </video>
        </a>
      <% when :speech %>
        <div class="gallery-speech-wrapper">
          <a href="<%= item[:url] %>" class="glightbox glightbox-civil" data-gallery="civil" data-type="video">
            <video width="100%" autoplay loop muted playsinline oncontextmenu="return false;">
              <source src="<%= item[:url] %>" type="video/mp4">
            </video>
          </a>
          <button class="gallery-speech-badge"
                  data-label-muted="🔊 <%= t 'photo.has_audio' %>"
                  data-label-unmuted="🔇 <%= t 'photo.mute' %>"
                  onclick="var v=this.closest('.gallery-speech-wrapper').querySelector('video');v.muted=!v.muted;this.textContent=v.muted?this.dataset.labelMuted:this.dataset.labelUnmuted;">
            🔊 <%= t 'photo.has_audio' %>
          </button>
        </div>
      <% end %>
    </div>
  <% end %>
</div>


<script>
  (function () {
    var silentHrefs = new Set();
    document.querySelectorAll('a.glightbox[data-mute="true"]').forEach(function (el) {
      silentHrefs.add(el.getAttribute('href'));
    });

    function muteSilentVideo() {
      setTimeout(function () {
        var slide = document.querySelector('.gslide.current');
        if (!slide) return;
        var video = slide.querySelector('video');
        if (!video) return;
        var source = slide.querySelector('source');
        if (source && silentHrefs.has(source.getAttribute('src'))) video.muted = true;
      }, 200);
    }

    function columnCount() {
      return window.innerWidth <= 600 ? 1 : window.innerWidth <= 800 ? 2 : 4;
    }

    function initGallery(rowId, selector) {
      var row = document.getElementById(rowId);
      if (!row) return;
      var items = Array.from(row.querySelectorAll('.gallery-item'));

      function distribute() {
        var n = columnCount();
        row.innerHTML = '';
        var cols = Array.from({ length: n }, function () {
          var col = document.createElement('div');
          col.className = 'gallery-column';
          row.appendChild(col);
          return col;
        });
        items.forEach(function (item, i) { cols[i % n].appendChild(item); });
        row.querySelectorAll('img').forEach(function (img) {
          if (img.complete) img.classList.add('loaded');
        });
      }

      distribute();

      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(distribute, 100);
      });

      var lb = GLightbox({ selector: selector, touchNavigation: true, loop: false });
      lb.on('open', muteSilentVideo);
      lb.on('slide_changed', muteSilentVideo);
    }

    initGallery('gallery-row-civil', '.glightbox-civil');
    initGallery('gallery-row-ceremonial', '.glightbox-ceremonial');
  })();
</script>
